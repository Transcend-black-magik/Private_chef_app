[debug] [2026-05-04T14:14:37.669Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/cook-for-me-8002d/rulesets {"name":"projects/cook-for-me-8002d/rulesets/9b964b06-a35a-41f5-9319-86051a0b248e","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function signedIn() {\n      return request.auth != null;\n    }\n\n    function currentEmail() {\n      return signedIn() && request.auth.token.email is string\n        ? request.auth.token.email\n        : \"\";\n    }\n\n    function isOwner(userId) {\n      return signedIn() && request.auth.uid == userId;\n    }\n\n    function isSignedInUsersOwnEmail() {\n      return signedIn() &&\n        request.auth.token.email is string &&\n        resource.data.email is string &&\n        request.auth.token.email == resource.data.email;\n    }\n\n    function matchesCurrentAccount(identifier) {\n      return signedIn() && (\n        identifier == request.auth.uid ||\n        (currentEmail() != \"\" && identifier == currentEmail())\n      );\n    }\n\n    function participantListHasCurrentAccount(participantIds) {\n      return participantIds is list && (\n        request.auth.uid in participantIds ||\n        (currentEmail() != \"\" && currentEmail() in participantIds)\n      );\n    }\n\n    function bookingExplorerMutableKeys() {\n      return [\n        \"dishSummary\",\n        \"serviceDateLabel\",\n        \"guestCount\",\n        \"areaLabel\",\n        \"serviceMode\",\n        \"serviceKind\",\n        \"needsMarketTrip\",\n        \"ingredientBudgetAmount\",\n        \"notes\",\n        \"subtotalAmount\",\n        \"explorerFeeAmount\",\n        \"cookFeeAmount\",\n        \"platformFeeAmount\",\n        \"totalAmount\",\n        \"payoutAmount\",\n        \"latestOfferAmount\",\n        \"latestOfferBy\",\n        \"latestOfferNote\",\n        \"negotiationOpen\",\n        \"cancellationReason\",\n        \"fundsReleaseStatus\",\n        \"trustReleaseConfirmed\",\n        \"instantMatch\",\n        \"deliveryMode\",\n        \"status\",\n        \"updatedAt\"\n      ];\n    }\n\n    function bookingCookMutableKeys() {\n      return [\n        \"subtotalAmount\",\n        \"explorerFeeAmount\",\n        \"cookFeeAmount\",\n        \"platformFeeAmount\",\n        \"totalAmount\",\n        \"payoutAmount\",\n        \"latestOfferAmount\",\n        \"latestOfferBy\",\n        \"latestOfferNote\",\n        \"negotiationOpen\",\n        \"cancellationReason\",\n        \"deliveryMode\",\n        \"status\",\n        \"updatedAt\"\n      ];\n    }\n\n    function chatThreadMutableKeys() {\n      return [\n        \"bookingStatus\",\n        \"lastMessageText\",\n        \"lastMessageSenderId\",\n        \"lastMessageAt\",\n        \"updatedAt\",\n        \"messageCount\",\n        \"unreadCountBy\",\n        \"lastReadAtBy\",\n        \"isBlocked\",\n        \"archivedBy\",\n        \"hiddenBy\"\n      ];\n    }\n\n    function isParticipant(data) {\n      return signedIn() && (\n        matchesCurrentAccount(data.explorerId) ||\n        matchesCurrentAccount(data.cookId) ||\n        participantListHasCurrentAccount(data.participantIds)\n      );\n    }\n\n    match /users/{userId} {\n      allow create: if isOwner(userId);\n      allow update: if isOwner(userId);\n      allow read: if signedIn() && (\n        isOwner(userId) ||\n        isSignedInUsersOwnEmail() ||\n        (\n          resource.data.role == \"cook\" &&\n          resource.data.profileComplete == true\n        )\n      );\n    }\n\n    match /cookVerificationQueue/{userId} {\n      allow create, update, read: if isOwner(userId);\n    }\n\n    match /bookingRequests/{bookingId} {\n      allow create: if signedIn() &&\n        matchesCurrentAccount(request.resource.data.explorerId);\n      allow read: if isParticipant(resource.data);\n      allow update: if signedIn() && (\n        (\n          matchesCurrentAccount(resource.data.explorerId) &&\n          request.resource.data.diff(resource.data).changedKeys().hasOnly(bookingExplorerMutableKeys())\n        ) ||\n        (\n          matchesCurrentAccount(resource.data.cookId) &&\n          request.resource.data.diff(resource.data).changedKeys().hasOnly(bookingCookMutableKeys())\n        )\n      );\n    }\n\n    match /chatThreads/{threadId} {\n      allow create: if signedIn() &&\n        matchesCurrentAccount(request.resource.data.explorerId) &&\n        participantListHasCurrentAccount(request.resource.data.participantIds);\n      allow read: if isParticipant(resource.data);\n      allow update: if isParticipant(resource.data) &&\n        request.resource.data.diff(resource.data).changedKeys().hasOnly(chatThreadMutableKeys());\n\n      match /messages/{messageId} {\n        allow create: if signedIn() &&\n          participantListHasCurrentAccount(\n            get(/databases/$(database)/documents/chatThreads/$(threadId)).data.participantIds\n          ) &&\n          matchesCurrentAccount(request.resource.data.senderId);\n        allow read: if signedIn() &&\n          participantListHasCurrentAccount(\n            get(/databases/$(database)/documents/chatThreads/$(threadId)).data.participantIds\n          );\n      }\n    }\n\n    match /payments/{paymentId} {\n      allow create: if signedIn() && matchesCurrentAccount(request.resource.data.explorerId);\n      allow read: if isParticipant(resource.data);\n      allow update: if signedIn() &&\n        matchesCurrentAccount(resource.data.explorerId) &&\n        matchesCurrentAccount(request.resource.data.explorerId) &&\n        request.resource.data.diff(resource.data).changedKeys().hasOnly([\n          \"status\",\n          \"provider\",\n          \"updatedAt\",\n          \"amount\",\n          \"subtotalAmount\",\n          \"ingredientBudgetAmount\",\n          \"explorerFeeAmount\",\n          \"cookFeeAmount\",\n          \"platformFeeAmount\",\n          \"payoutAmount\",\n          \"currencyCode\"\n        ]);\n    }\n\n    match /notifications/{notificationId} {\n      allow create: if signedIn();\n      allow read: if signedIn() && matchesCurrentAccount(resource.data.recipientId);\n      allow update: if signedIn() &&\n        matchesCurrentAccount(resource.data.recipientId) &&\n        request.resource.data.diff(resource.data).changedKeys().hasOnly([\n          \"read\"\n        ]);\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-05-04T14:14:38.341487Z","metadata":{"services":["cloud.firestore"]}}
