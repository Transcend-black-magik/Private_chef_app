# Server-side verification provider values.
# Add these to your Firebase Functions environment or secrets, not the app .env:
# DOJAH_APP_ID=
# DOJAH_SECRET_KEY=
# DOJAH_BASE_URL=https://sandbox.dojah.io

# Server-side AI values. Never put the actual OpenAI key in the Expo app .env.
# Set this as a Firebase Functions secret:
# firebase functions:secrets:set OPENAI_API_KEY
# Or for the local proxy:
# OPENAI_API_KEY=your_new_rotated_key
# npm run food-ai:proxy
# Optional Functions env value:
# FOOD_AI_MODEL=gpt-5.5

