EXPO_PUBLIC_SUPABASE_URL=https://dxazxhgmeracydzumfcx.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=your_publishable_key
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=
EXPO_OWNER=
EXPO_PUBLIC_EAS_PROJECT_ID=

# Optional relay used by the app to send Expo push notifications from Supabase auth.
# Local Android emulator example:
# EXPO_PUBLIC_PUSH_RELAY_ENDPOINT=http://10.0.2.2:8788/push-notify
# Local iOS simulator example:
# EXPO_PUBLIC_PUSH_RELAY_ENDPOINT=http://127.0.0.1:8788/push-notify
EXPO_PUBLIC_PUSH_RELAY_ENDPOINT=

# Optional fallback if you use a custom HTTPS endpoint instead of a Supabase Edge Function.
# Local Android emulator example:
# EXPO_PUBLIC_FOOD_AI_ENDPOINT=http://10.0.2.2:8787/food-ai
# Local iOS simulator example:
# EXPO_PUBLIC_FOOD_AI_ENDPOINT=http://127.0.0.1:8787/food-ai
# Physical iPhone example:
# EXPO_PUBLIC_FOOD_AI_ENDPOINT=http://YOUR_LAPTOP_IP:8787/food-ai
# Leave blank in production; the app calls the Supabase foodAssistant Edge Function first.
EXPO_PUBLIC_FOOD_AI_ENDPOINT=

# Server-side only values for scripts or Supabase Edge Functions. Never put secrets in the Expo app bundle.
SUPABASE_URL=https://dxazxhgmeracydzumfcx.supabase.co
SUPABASE_ANON_KEY=your_anon_or_publishable_key
SUPABASE_SERVICE_ROLE_KEY=
DOJAH_APP_ID=
DOJAH_SECRET_KEY=
DOJAH_BASE_URL=https://sandbox.dojah.io
OPENAI_API_KEY=
FOOD_AI_MODEL_CANDIDATES=gpt-5.5,gpt-5.4,gpt-4.1,gpt-4.1-mini
FOOD_AI_FAST_MODEL=gpt-4.1-mini
FOOD_AI_LARGE_MODEL=gpt-4.1
ASSISTANT_CACHE_TTL_SECONDS=900
